{
  "name": "insforge-ai-pdf-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "auth:migrate": "npx -y auth@latest migrate --config ./lib/auth.ts -y",
    "setup": "npm run auth:migrate && npx -y @insforge/cli storage create-bucket pdf-documents --private && npx -y @insforge/cli storage create-bucket audio-overviews --public",
    "test": "node --import tsx --test scripts/*.test.mjs"
  },
  "dependencies": {
    "@insforge/sdk": "latest",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.446.0",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-pdf": "^10.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "24.6.2",
    "@types/pg": "^8.11.10",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
